# Telegram Bot — заявки з форм на сайті → повідомлення вам у Telegram
# 1. @BotFather → /newbot → скопіюйте токен
# 2. Напишіть боту /start
# 3. npm run telegram:setup  (покаже chat_id)
# 4. Додайте обидві змінні в Vercel → Redeploy
# Детально: docs/TELEGRAM-SETUP.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Особистий Telegram для кошика (посилання t.me/...) — у src/config/site.ts
# username: max_nutrition_bot

# Upstash Redis (аналітика переглядів, трендові продукти)
# Vercel → Storage → Upstash Redis → Connect to project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Публічний URL сайту (для sitemap)
SITE_URL=https://max-nutrition.in.ua
